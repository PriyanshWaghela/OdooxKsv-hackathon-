{
  "name": "vendorbridge-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "clsx": "^2.1.1",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.394.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.1",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.3.0"
  },
  "scripts": {
    "start": "concurrently \"react-scripts start\" \"npx tailwindcss -i ./src/index.css -o ./src/output.css --watch\"",
    "build": "npx tailwindcss -i ./src/index.css -o ./src/output.css && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.3.2"
  },
  "proxy": "http://localhost:5000"
}
